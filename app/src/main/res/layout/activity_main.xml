<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="État : aucune action"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="16dp"
        android:background="#f0f0f0"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnToggleAirplane"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activer récepteur mode avion"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnCheckAirplane"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vérifier état mode avion"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSendCustom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Envoyer broadcast custom" />

</LinearLayout>